      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="updateRoom">
        <dc:Bounds x="790" y="320" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="notifyReject">
        <dc:Bounds x="1490" y="200" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="notifyApprove">
        <dc:Bounds x="1490" y="50" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="EndReject">
        <dc:Bounds x="1902" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1882" y="265" width="77" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="EndApprove">
        <dc:Bounds x="1680" y="72" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1663" y="115" width="72" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="loopGateway" isMarkerVisible="true">
        <dc:Bounds x="1680" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1679" y="180" width="52" height="14" />
